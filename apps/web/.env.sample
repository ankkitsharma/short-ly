# API URL (server-side)
SERVER_URL=http://localhost:3001

# API URL (client-side)
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Database (Neon)
# Pooled connection (use -pooler hostname) — used at runtime by the app
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/shortly?sslmode=require
# Direct connection (no -pooler) — used by Prisma CLI (migrations)
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/shortly?sslmode=require
